# Название приложения, которое будет отображаться в интерфейсе.
APP_NAME=LT Report Analyzer

# Хост и порт, на которых запускается само веб-приложение.
APP_HOST=0.0.0.0
APP_PORT=8000

# Секретный ключ для сессий FastAPI.
SECRET_KEY=change-me

# Настройки локального PostgreSQL.
# Здесь нужно указать реальные параметры своей БД.
POSTGRES_DB=lt_reports
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Внутренний адрес Grafana для контейнера приложения.
GRAFANA_URL=http://grafana:3000

# Публичный адрес Grafana для переходов из браузера и отчетов.
GRAFANA_PUBLIC_URL=http://localhost:3000

# Учетные данные администратора Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Токен для сервиса рендера графиков Grafana.
GRAFANA_RENDERER_TOKEN=lt-report-renderer-token

# Внутренний адрес InfluxDB для контейнера приложения.
INFLUXDB_URL=http://influxdb:8086

# Публичный адрес InfluxDB для доступа с хост-машины.
INFLUXDB_PUBLIC_URL=http://localhost:8086

# Начальные учетные данные InfluxDB.
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345
INFLUXDB_ORG=lt-report
INFLUXDB_BUCKET=lt-metrics
INFLUXDB_TOKEN=lt-report-token

# Внутренний адрес Prometheus для контейнера приложения.
PROMETHEUS_URL=http://prometheus:9090

# Публичный адрес Prometheus для доступа с хост-машины.
PROMETHEUS_PUBLIC_URL=http://localhost:9090

# Логин и пароль администратора приложения,
# который будет создан автоматически при первом запуске.
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123
