# Название приложения, которое отображается в интерфейсе.
APP_NAME=Анализ результатов

# Адрес и порт запуска веб-приложения.
APP_HOST=0.0.0.0
APP_PORT=8000

# Секретный ключ для сессий.
SECRET_KEY=change-me

# Параметры подключения к PostgreSQL.
POSTGRES_DB=lt_reports
POSTGRES_USER=lt_user
POSTGRES_PASSWORD=lt_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Настройки Grafana.
GRAFANA_URL=http://localhost:3000
GRAFANA_PUBLIC_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_RENDERER_TOKEN=lt-report-renderer-token
GRAFANA_DASHBOARD_UID=ffk6d9oj24kqoc
GRAFANA_DASHBOARD_SLUG=load-testing-overview

# Настройки InfluxDB.
INFLUXDB_URL=http://localhost:8086
INFLUXDB_PUBLIC_URL=http://localhost:8086
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin12345
INFLUXDB_ORG=lt-report
INFLUXDB_BUCKET=lt-metrics
INFLUXDB_TOKEN=lt-report-token

# Настройки Prometheus.
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_PUBLIC_URL=http://localhost:9090
PROMETHEUS_INSTANCE=app-lt1:9100
PROMETHEUS_JOB=node-exporter

# Часовой пояс для отчетов.
REPORT_TIMEZONE=Europe/Moscow

# Данные администратора по умолчанию.
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=admin123
